{
  "expo": {
    "name": "MeAndMySelf",
    "slug": "myself",
    "version": "1.2.4",
    "scheme": "myself",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "backgroundColor": "#0b0c10",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.navesarussi.myself",
      "infoPlist": {
        "CFBundleDevelopmentRegion": "he",
        "ITSAppUsesNonExemptEncryption": false,
        "RCTNewArchEnabled": false
      }
    },
    "android": {
      "package": "com.navesarussi.myself",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b0c10"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0b0c10"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "supportsRTL": true,
      "router": {},
      "eas": {
        "projectId": "6f81d110-b64f-4339-8dc2-2c93ae180fe8"
      }
    },
    "owner": "saussilberg"
  }
}
