{
  "expo": {
    "name": "MeAndMySelf",
    "slug": "myself",
    "version": "1.9.5",
    "scheme": "myself",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "backgroundColor": "#0b0c10",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.navesarussi.myself",
      "infoPlist": {
        "CFBundleDevelopmentRegion": "he",
        "ITSAppUsesNonExemptEncryption": false,
        "RCTNewArchEnabled": false,
        "NSContactsUsageDescription": "לאפשר ל-MeAndMySelf לקרוא אנשי קשר כדי למלא פרטי קשר חדשים."
      }
    },
    "android": {
      "package": "com.navesarussi.myself",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "expo-screen-orientation",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0b0c10"
        }
      ],
      "expo-font",
      [
        "expo-contacts",
        {
          "contactsPermission": "לאפשר ל-MeAndMySelf לקרוא אנשי קשר כדי למלא פרטי קשר חדשים."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "supportsRTL": true,
      "router": {},
      "eas": {
        "projectId": "6f81d110-b64f-4339-8dc2-2c93ae180fe8"
      }
    },
    "owner": "saussilberg"
  }
}
