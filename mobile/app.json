{
  "expo": {
    "name": "מרכז השליטה",
    "slug": "myself",
    "version": "1.2.0",
    "scheme": "myself",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "backgroundColor": "#0b0c10",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.navesarussi.myself",
      "infoPlist": {
        "CFBundleDevelopmentRegion": "he",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.navesarussi.myself",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b0c10"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0b0c10"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "supportsRTL": true
    }
  }
}
