# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Site auth (Google Sign-In)
AUTH_SECRET=
ALLOWED_GOOGLE_EMAIL=

# Google OAuth (Sign-In + Calendar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Google Tasks OAuth (must match Google Cloud Console Authorized redirect URIs)
# Production: https://myselfapp.xyz/api/integrations/google-tasks/callback
GOOGLE_TASKS_REDIRECT_URI=http://localhost:3000/api/integrations/google-tasks/callback

# GitHub Issues OAuth App (Developer settings → OAuth Apps)
# Production: https://myselfapp.xyz/api/integrations/github/callback
# Callback URL must match; scopes: repo, read:user
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/api/integrations/github/callback

# Monday.com OAuth (multi-account task source)
# Production: https://myselfapp.xyz/api/integrations/monday/callback
MONDAY_CLIENT_ID=
MONDAY_CLIENT_SECRET=
MONDAY_REDIRECT_URI=http://localhost:3000/api/integrations/monday/callback

CRON_SECRET=
